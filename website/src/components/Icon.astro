    github: { path: SI_GITHUB, viewBox: "0 0 24 24" },
    "github-logo": { path: SI_GITHUB, viewBox: "0 0 24 24" },
    star: { path: OCTICON_STAR, viewBox: "0 0 16 16" },
  };

const mark = brand[name];
const path = mark?.path ?? phosphor[name] ?? "";
const viewBox = mark?.viewBox ?? "0 0 256 256";
---

<svg
  class:list={["icon", className]}
  width={size}
  height={size}
  viewBox={viewBox}
  fill="currentColor"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-hidden="true"
  focusable="false"
>
  <path d={path}></path>
</svg>
