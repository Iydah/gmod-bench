---
import {
  PAGE_METADATA,
  SITE,
  SOCIAL_IMAGE_PATH,
  canonicalUrl,
  type PageId,
} from "../content/site-content";
import { buildStructuredData, type JsonLdNode } from "../lib/seo";
import type { PublishedRun } from "../lib/published-runs";

interface Props {
  pageId: PageId;
  title?: string;
  description?: string;
  canonicalPath?: string;
  run?: PublishedRun;
  structuredData?: readonly JsonLdNode[];
}

const { pageId, title, description, canonicalPath, run, structuredData } =
  Astro.props;
const defaults = PAGE_METADATA[pageId];
const pageTitle = title ?? defaults.title;
const pageDescription = description ?? defaults.description;
const canonical = canonicalUrl(Astro.url, canonicalPath ?? defaults.path);
const socialImage = new URL(SOCIAL_IMAGE_PATH, SITE.url).toString();
const socialAlt = `${SITE.name} — compare AI models for Garry's Mod development`;
const jsonLd =
  structuredData ?? buildStructuredData(pageId, { canonical, run });
---

<title>{pageTitle}</title>
<meta name="description" content={pageDescription} />
<meta name="robots" content={defaults.robots} />
<link rel="canonical" href={canonical} />

<meta property="og:type" content={defaults.ogType} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={pageDescription} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content="en_GB" />
<meta property="og:image" content={socialImage} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={socialAlt} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={pageDescription} />
<meta name="twitter:image" content={socialImage} />
<meta name="twitter:image:alt" content={socialAlt} />

{
  jsonLd.map((node) => (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(node).replaceAll("<", "\\u003c")}
    />
  ))
}
