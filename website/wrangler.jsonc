{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gmod-bench",
  "compatibility_date": "2026-07-10",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
  "cache": {
    "enabled": true,
    "cross_version_cache": false,
  },
}
