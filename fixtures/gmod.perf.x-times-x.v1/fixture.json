    "rubricVersion": "2"
  },
  "scoring": {
    "kind": "regex",
    "passPatterns": [
      "(?:=|return|\\()\\s*(\\w+)\\s*\\*\\s*\\1",
      "(?:=|return|\\()\\s*\\w+\\s*\\^\\s*2"
    ],
    "partialPatterns": [],
    "incorrectPatterns": ["math\\.pow"]
  }
}
