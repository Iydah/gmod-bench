{
  "id": "gmod.perf.meta-vs-arg.v1",
  "version": 1,
  "title": "Metamethod call vs plain function argument",
  "prompt": "In Garry's Mod Lua, is ply:SomeHelper() generally faster or slower than SomeHelper(ply) for a helper you control?\n\nReturn exactly one fenced lua code block showing the preferred call style, then exactly one line in the form Reason: <reason>. Do not use tools or external resources.",
  "responseContract": {
    "codeFenceLanguage": "lua",
    "reasonPrefix": "Reason:",
    "maxReasonLines": 1,
    "minCandidateLoops": 0,
    "maxCandidateLoops": 0,
    "maxAnswerBytes": 2048
  },
  "oracle": {
    "expectedPrimitive": "SomeHelper(ply) avoids PLAYER __index",
    "sourceUrls": [
      "https://github.com/OverlordAkise/gmod-lua-performance",
      "https://github.com/OverlordAkise/gmod-lua-performance/blob/main/files/meta_vs_argument.lua"
    ],
    "verifiedAt": "2026-07-10",
    "rubricVersion": "1"
  },
  "scoring": {
    "kind": "regex",
    "passPatterns": [
      "function\\s+\\w+\\s*\\(\\s*ply\\b",
      "(?<![:.\\w])\\w+\\s*\\(\\s*ply\\s*\\)"
    ],
    "partialPatterns": [],
    "incorrectPatterns": [
      "ply\\s*:\\s*\\w+\\s*\\("
    ]
  }
}
