{
  "id": "gmod.perf.table-random.v1",
  "version": 1,
  "title": "Random element of sequential table",
  "prompt": "In Garry's Mod Lua, you need a random element from a sequential table. Show a faster approach than table.Random for that case.\n\nReturn exactly one fenced lua code block, then exactly one line in the form Reason: <reason>. Do not use tools or external resources.",
  "responseContract": {
    "codeFenceLanguage": "lua",
    "reasonPrefix": "Reason:",
    "maxReasonLines": 1,
    "minCandidateLoops": 0,
    "maxCandidateLoops": 0,
    "maxAnswerBytes": 2048
  },
  "oracle": {
    "expectedPrimitive": "t[math.random(#t)]",
    "sourceUrls": [
      "https://github.com/OverlordAkise/gmod-lua-performance",
      "https://github.com/OverlordAkise/gmod-lua-performance/blob/main/files/table_random_overwrite.lua"
    ],
    "verifiedAt": "2026-07-10",
    "rubricVersion": "2"
  },
  "scoring": {
    "kind": "regex",
    "passPatterns": [
      "math\\.random\\s*\\(\\s*#",
      "math\\.random\\s*\\(\\s*1\\s*,",
      "local\\s+(\\w+)\\s*=\\s*#\\s*(\\w+)[\\s\\S]{0,160}\\2\\s*\\[\\s*math\\.random\\s*\\(\\s*\\1\\s*\\)\\s*\\]",
      "local\\s+(\\w+)\\s*=\\s*math\\.random[\\s\\S]{0,240}local\\s+(\\w+)\\s*=\\s*#\\s*(\\w+)[\\s\\S]{0,160}\\3\\s*\\[\\s*\\1\\s*\\(\\s*(?:1\\s*,\\s*)?\\2\\s*\\)\\s*\\]"
    ],
    "partialPatterns": ["table\\.Random"],
    "incorrectPatterns": []
  }
}
