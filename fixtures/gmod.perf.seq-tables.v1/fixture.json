{
  "id": "gmod.perf.seq-tables.v1",
  "version": 1,
  "title": "Sequential number tables vs string-key tables",
  "prompt": "In Garry's Mod Lua, you will frequently iterate a fixed collection of values. It is currently stored as a string-keyed map. Show a table shape that iterates faster.\n\nReturn exactly one fenced lua code block, then exactly one line in the form Reason: <reason>. Do not use tools or external resources.",
  "responseContract": {
    "codeFenceLanguage": "lua",
    "reasonPrefix": "Reason:",
    "maxReasonLines": 1,
    "minCandidateLoops": 0,
    "maxCandidateLoops": 1,
    "maxAnswerBytes": 2048
  },
  "oracle": {
    "expectedPrimitive": "sequential number-indexed table + ipairs/for",
    "sourceUrls": [
      "https://github.com/OverlordAkise/gmod-lua-performance",
      "https://github.com/OverlordAkise/gmod-lua-performance/blob/main/files/string_vs_number_table.lua"
    ],
    "verifiedAt": "2026-07-10",
    "rubricVersion": "2"
  },
  "scoring": {
    "kind": "regex",
    "passPatterns": [
      "\\{\\s*[^}]*\\d+\\s*,",
      "\\{\\s*[\"'][^\"']+[\"']\\s*,",
      "for\\s+\\w+\\s*=\\s*1\\s*,\\s*#",
      "ipairs\\s*\\("
    ],
    "partialPatterns": ["pairs\\s*\\("],
    "incorrectPatterns": []
  }
}
